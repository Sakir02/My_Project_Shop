{
  "version": 2,
  "builds": [
    { "src": "myprojects/wsgi.py", "use": "@vercel/python" },
    { "src": "build_files.sh", "use": "@vercel/static-build", "config": { "distDir": "staticfiles" } }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/staticfiles/$1" },
    { "src": "/(.*)", "dest": "myprojects/wsgi.py" }
  ]
}